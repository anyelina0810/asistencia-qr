# ============================================================
# .env.example — Copia este archivo como .env y configura.
# NUNCA commitees .env a git.
# ============================================================

# Puerto del servidor
PORT=3000

# Secret JWT — usa uno aleatorio y seguro en producción
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTE_SECRET_EN_PRODUCCION

# Expiración de tokens JWT
JWT_EXPIRES=8h

# Ruta a la base de datos SQLite
DB_PATH=./database/attendance.db

# Origen permitido para CORS (en producción, pon tu dominio)
ALLOWED_ORIGIN=http://localhost:3000

# Entorno
NODE_ENV=development
